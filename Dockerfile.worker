# Stage 1: build — compile TypeScript
FROM node:20-slim AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY tsconfig.json ./
COPY src/ ./src/
RUN npx tsc


# Stage 2: runtime — Playwright image with compiled output
FROM mcr.microsoft.com/playwright:v1.44.0-jammy

WORKDIR /app

# Copy deps and compiled output from build stage
COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/dist ./dist

CMD ["node", "dist/worker.js"]
